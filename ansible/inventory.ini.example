[mq_servers]
# Add your MQ server hostnames or IP addresses here
# Example:
# mq-prod-01.example.com
# mq-prod-02.example.com
# 192.168.1.50

[mq_servers:vars]
# Define standard connection variables here
ansible_user=mqm
ansible_ssh_private_key_file=~/.ssh/id_rsa
# Set to 'ssh' for Linux targets, or 'winrm' for Windows targets.
ansible_connection=ssh

# If you are targeting Windows, you'll need parameters like these:
# ansible_connection=winrm
# ansible_winrm_server_cert_validation=ignore
# ansible_winrm_transport=ntlm
